{
  "name": "file-converter",
  "version": "1.0.0",
  "description": "길건축 파일 형식 변환기",

  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },

  "build": {
    "appId": "com.gilgroup.fileconverter",

    "productName": "Gil File Converter",

    "asar": true,

    "directories": {
      "output": "dist"
    },

    "win": {
      "target": "nsis",
      "icon": "app-icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,

      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,

      "shortcutName": "파일 형식 변환기"
    }
  },

  "devDependencies": {
    "electron": "^25.7.0",
    "electron-builder": "^24.0.0"
  }
}